{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-infosys-demo-dev"
		},
		"AKV_src_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://sql-username.vault.azure.net/"
		},
		"AKV_tar_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://sql-username-tar.vault.azure.net/"
		},
		"AzureSqlDatabase_src_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "@{linkedService().sqlservername}"
		},
		"AzureSqlDatabase_src_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().sqldbname}"
		},
		"AzureSqlDatabase_src_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"AzureSqlDatabase_tar_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "@{linkedService().sqlservername}"
		},
		"AzureSqlDatabase_tar_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "@{linkedService().sqldbname}"
		},
		"AzureSqlDatabase_tar_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-infosys-demo-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AKV_src_properties_typeProperties_baseUrl": {
						"value": "[parameters('AKV_src_properties_typeProperties_baseUrl')]"
					},
					"AKV_tar_properties_typeProperties_baseUrl": {
						"value": "[parameters('AKV_tar_properties_typeProperties_baseUrl')]"
					},
					"AzureSqlDatabase_src_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_src_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_src_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_src_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_src_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_src_properties_typeProperties_userName')]"
					},
					"AzureSqlDatabase_tar_properties_typeProperties_server": {
						"value": "[parameters('AzureSqlDatabase_tar_properties_typeProperties_server')]"
					},
					"AzureSqlDatabase_tar_properties_typeProperties_database": {
						"value": "[parameters('AzureSqlDatabase_tar_properties_typeProperties_database')]"
					},
					"AzureSqlDatabase_tar_properties_typeProperties_userName": {
						"value": "[parameters('AzureSqlDatabase_tar_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}