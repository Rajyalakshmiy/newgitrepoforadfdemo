{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-infosys-demo-dev"
		},
		"trigger1_properties_typeProperties_recurrence_frequency": {
			"type": "string",
			"defaultValue": "Day"
		},
		"trigger1_properties_typeProperties_recurrence_interval": {
			"type": "int",
			"defaultValue": 5
		},
		"trigger1_properties_typeProperties_recurrence_startTime": {
			"type": "string",
			"defaultValue": "2026-06-11T14:22:00"
		},
		"trigger1_properties_typeProperties_recurrence_timeZone": {
			"type": "string",
			"defaultValue": "India Standard Time"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-infosys-demo-dev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"trigger1_properties_typeProperties_recurrence_frequency": {
						"value": "[parameters('trigger1_properties_typeProperties_recurrence_frequency')]"
					},
					"trigger1_properties_typeProperties_recurrence_interval": {
						"value": "[parameters('trigger1_properties_typeProperties_recurrence_interval')]"
					},
					"trigger1_properties_typeProperties_recurrence_startTime": {
						"value": "[parameters('trigger1_properties_typeProperties_recurrence_startTime')]"
					},
					"trigger1_properties_typeProperties_recurrence_timeZone": {
						"value": "[parameters('trigger1_properties_typeProperties_recurrence_timeZone')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}